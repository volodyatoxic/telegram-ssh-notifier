#!/bin/bash

# ─────────────────────────────────────────────
#   tgnotify — Telegram SSH Notifier CLI
# ─────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

CONFIG_FILE="/etc/tg-ssh-notifier/config"
NOTIFY_BIN="/usr/local/bin/tg-ssh-notifier"
CLI_BIN="/usr/local/bin/tgnotify"
PAM_FILE="/etc/pam.d/sshd"

# ── helpers ──────────────────────────────────

ok()  { echo -e "  ${GREEN}✔${NC}  $1"; }
err() { echo -e "  ${RED}✖${NC}  $1"; }
inf() { echo -e "  ${CYAN}▸${NC} $1"; }
sep() { echo -e "  ${DIM}────────────────────────────────────────${NC}"; }

require_root() {
    if [ "$EUID" -ne 0 ]; then
        err "Требуются права root. Запустите через sudo."
        exit 1
    fi
}

require_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        err "Конфиг не найден. Сначала запустите установку."
        exit 1
    fi
}

load_config() {
    require_config
    source "$CONFIG_FILE"
}

save_config() {
    cat > "$CONFIG_FILE" <<CONF
TOKEN="$TOKEN"
USER_IDS="$USER_IDS"
SERVER_NAME="$SERVER_NAME"
CONF
    chmod 600 "$CONFIG_FILE"
}

print_banner() {
    echo ""
    echo -e "${BLUE}${BOLD}  ╔══════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}${BOLD}  ║    🔔 Telegram SSH Notifier · tgnotify   ║${NC}"
    echo -e "${BLUE}${BOLD}  ╚══════════════════════════════════════════╝${NC}"
    echo ""
}

# ── commands ─────────────────────────────────

cmd_help() {
    print_banner
    echo -e "  ${BOLD}Использование:${NC}  tgnotify <команда> [аргументы]"
    echo ""
    echo -e "  ${YELLOW}${BOLD}Управление конфигом:${NC}"
    echo -e "  ${CYAN}set-token${NC}            Изменить Bot API Token"
    echo -e "  ${CYAN}add-user${NC} <id>        Добавить Telegram User ID"
    echo -e "  ${CYAN}remove-user${NC} <id>     Удалить Telegram User ID"
    echo -e "  ${CYAN}set-server${NC} <name>    Переименовать сервер"
    echo ""
    echo -e "  ${YELLOW}${BOLD}Диагностика:${NC}"
    echo -e "  ${CYAN}status${NC}               Показать текущий конфиг"
    echo -e "  ${CYAN}test${NC}                 Отправить тестовое сообщение"
    echo ""
    echo -e "  ${YELLOW}${BOLD}Удаление:${NC}"
    echo -e "  ${CYAN}uninstall${NC}            Полностью удалить программу"
    echo ""
    echo -e "  ${DIM}Примеры:${NC}"
    echo -e "  ${DIM}  sudo tgnotify set-token${NC}"
    echo -e "  ${DIM}  sudo tgnotify add-user 123456789${NC}"
    echo -e "  ${DIM}  sudo tgnotify set-server \"My VPS\"${NC}"
    echo ""
}

cmd_status() {
    load_config
    print_banner
    echo -e "  ${BOLD}Текущая конфигурация${NC}"
    sep
    echo ""
    echo -e "  🖥️   ${BOLD}Сервер:${NC}    $SERVER_NAME"
    echo -e "  🤖  ${BOLD}Token:${NC}     ${TOKEN:0:10}…${TOKEN: -4} ${DIM}(скрыт)${NC}"
    echo -e "  👥  ${BOLD}User IDs:${NC}  $USER_IDS"
    echo ""

    # PAM status
    if grep -q "tg-ssh-notifier" "$PAM_FILE" 2>/dev/null; then
        echo -e "  ${GREEN}●${NC}  PAM активен"
    else
        echo -e "  ${RED}●${NC}  PAM не настроен"
    fi

    [ -x "$NOTIFY_BIN" ] && echo -e "  ${GREEN}●${NC}  Notify-скрипт на месте" \
                         || echo -e "  ${RED}●${NC}  Notify-скрипт отсутствует"
    echo ""
}

cmd_set_token() {
    require_root
    load_config
    echo ""
    echo -e "  ${BOLD}Смена Bot API Token${NC}"
    sep
    echo ""
    echo -e "  Текущий: ${DIM}${TOKEN:0:10}…${TOKEN: -4}${NC}"
    read -p "  Новый токен: " NEW_TOKEN
    echo ""
    if [ -z "$NEW_TOKEN" ]; then
        err "Токен не может быть пустым."
        exit 1
    fi
    TOKEN="$NEW_TOKEN"
    save_config
    # Update the notify script with new token (it reads from config, so just save)
    ok "Token обновлён."
    echo ""
}

cmd_add_user() {
    require_root
    load_config
    NEW_ID="$1"
    if [ -z "$NEW_ID" ]; then
        echo ""
        read -p "  Введите Telegram User ID: " NEW_ID
        echo ""
    fi
    if [ -z "$NEW_ID" ]; then
        err "ID не может быть пустым."
        exit 1
    fi
    # Check duplicate
    IFS=',' read -ra CURRENT_IDS <<< "$USER_IDS"
    for id in "${CURRENT_IDS[@]}"; do
        if [ "$(echo "$id" | tr -d ' ')" = "$(echo "$NEW_ID" | tr -d ' ')" ]; then
            err "User ID $NEW_ID уже добавлен."
            exit 1
        fi
    done
    if [ -z "$USER_IDS" ]; then
        USER_IDS="$NEW_ID"
    else
        USER_IDS="$USER_IDS,$NEW_ID"
    fi
    save_config
    ok "User ID $NEW_ID добавлен."
    inf "Текущий список: $USER_IDS"
    echo ""
}

cmd_remove_user() {
    require_root
    load_config
    DEL_ID="$1"
    if [ -z "$DEL_ID" ]; then
        echo ""
        inf "Текущие User IDs: $USER_IDS"
        read -p "  Введите ID для удаления: " DEL_ID
        echo ""
    fi
    if [ -z "$DEL_ID" ]; then
        err "ID не может быть пустым."
        exit 1
    fi
    NEW_LIST=""
    IFS=',' read -ra CURRENT_IDS <<< "$USER_IDS"
    FOUND=0
    for id in "${CURRENT_IDS[@]}"; do
        clean="$(echo "$id" | tr -d ' ')"
        if [ "$clean" = "$(echo "$DEL_ID" | tr -d ' ')" ]; then
            FOUND=1
        else
            [ -z "$NEW_LIST" ] && NEW_LIST="$clean" || NEW_LIST="$NEW_LIST,$clean"
        fi
    done
    if [ "$FOUND" -eq 0 ]; then
        err "User ID $DEL_ID не найден."
        exit 1
    fi
    USER_IDS="$NEW_LIST"
    save_config
    ok "User ID $DEL_ID удалён."
    inf "Текущий список: ${USER_IDS:-<пусто>}"
    echo ""
}

cmd_set_server() {
    require_root
    load_config
    NEW_NAME="$*"
    if [ -z "$NEW_NAME" ]; then
        echo ""
        echo -e "  Текущее имя: ${BOLD}$SERVER_NAME${NC}"
        read -p "  Новое название сервера: " NEW_NAME
        echo ""
    fi
    if [ -z "$NEW_NAME" ]; then
        err "Название не может быть пустым."
        exit 1
    fi
    SERVER_NAME="$NEW_NAME"
    save_config
    ok "Сервер переименован: $SERVER_NAME"
    echo ""
}

cmd_test() {
    load_config
    echo ""
    inf "Отправка тестового сообщения..."
    echo ""
    FIRST_ID=$(echo "$USER_IDS" | cut -d',' -f1 | tr -d ' ')
    RESULT=$(curl -s -X POST "https://api.telegram.org/bot${TOKEN}/sendMessage" \
        -d "chat_id=$FIRST_ID" \
        -d "parse_mode=Markdown" \
        -d "text=🔔 *${SERVER_NAME}* · тест соединения ✅")
    if echo "$RESULT" | grep -q '"ok":true'; then
        ok "Сообщение доставлено пользователю $FIRST_ID"
    else
        ERR_MSG=$(echo "$RESULT" | grep -o '"description":"[^"]*"' | cut -d'"' -f4)
        err "Ошибка отправки: ${ERR_MSG:-неизвестная ошибка}"
        err "Ответ API: $RESULT"
    fi
    echo ""
}

cmd_uninstall() {
    require_root
    echo ""
    echo -e "  ${RED}${BOLD}Удаление Telegram SSH Notifier${NC}"
    sep
    echo ""
    echo -e "  Будет удалено:"
    echo -e "  ${DIM}  · $NOTIFY_BIN${NC}"
    echo -e "  ${DIM}  · $CLI_BIN${NC}"
    echo -e "  ${DIM}  · /etc/tg-ssh-notifier/${NC}"
    echo -e "  ${DIM}  · запись в /etc/pam.d/sshd${NC}"
    echo ""
    read -p "  Подтвердите удаление (yes/no): " CONFIRM
    echo ""
    if [ "$CONFIRM" != "yes" ]; then
        inf "Отменено."
        echo ""
        exit 0
    fi

    # Remove PAM entry
    if grep -q "tg-ssh-notifier" "$PAM_FILE" 2>/dev/null; then
        sed -i '/tg-ssh-notifier/d' "$PAM_FILE"
        ok "Запись PAM удалена"
    fi

    # Remove files
    rm -f "$NOTIFY_BIN"   && ok "Удалён: $NOTIFY_BIN"
    rm -rf "/etc/tg-ssh-notifier" && ok "Удалён: /etc/tg-ssh-notifier/"

    # Remove CLI last (this script itself)
    rm -f "$CLI_BIN"
    echo -e "  ${GREEN}✔${NC}  Удалён: $CLI_BIN"

    echo ""
    echo -e "  ${GREEN}${BOLD}Программа полностью удалена.${NC}"
    echo ""
}

# ── router ───────────────────────────────────

COMMAND="$1"
shift

case "$COMMAND" in
    help|--help|-h|"") cmd_help ;;
    status)             cmd_status ;;
    set-token)          cmd_set_token "$@" ;;
    add-user)           cmd_add_user "$@" ;;
    remove-user)        cmd_remove_user "$@" ;;
    set-server)         cmd_set_server "$@" ;;
    test)               cmd_test ;;
    uninstall)          cmd_uninstall ;;
    *)
        echo ""
        err "Неизвестная команда: $COMMAND"
        inf "Используйте: tgnotify help"
        echo ""
        exit 1
        ;;
esac
